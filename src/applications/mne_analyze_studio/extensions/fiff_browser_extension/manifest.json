{
  "id": "fiff-browser-extension",
  "display_name": "FIFF Browser Extension",
  "version": "0.1.0",
  "entry_point": "fiff_browser_embedded",
  "contributes": {
    "view_providers": [
      {
        "id": "fiffbrowser.raw_view",
        "display_name": "FIFF Raw Browser",
        "widget_type": "embedded_raw_browser",
        "slot": "center",
        "file_extensions": [
          ".fif",
          ".ave",
          ".edf"
        ],
        "supports_scene_merging": false,
        "initial_state": {
          "buffer_kind": "fiff",
          "session_role": "signal_browser"
        },
        "state_schema": {
          "type": "object",
          "properties": {
            "buffer_kind": {
              "type": "string"
            },
            "session_role": {
              "type": "string"
            }
          },
          "required": [
            "buffer_kind",
            "session_role"
          ]
        }
      }
    ],
    "tools": [
      {
        "name": "fiffbrowser.reveal_active_state",
        "description": "Reveal the currently active FIFF browser state in the hosted view session.",
        "input_schema": {
          "type": "object",
          "properties": {},
          "required": []
        },
        "result_schema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "title": "Status"
            }
          },
          "required": [
            "status"
          ]
        }
      }
    ],
    "ui": {
      "sidebar_items": [
        "FIFF Browser"
      ],
      "menu_items": [
        "View/FIFF Browser"
      ],
      "settings_tabs": [
        {
          "id": "raw_browser_preferences",
          "title": "Raw Browser Preferences",
          "description": "Settings contributed by the FIFF browser extension.",
          "fields": [
            {
              "id": "default_zoom",
              "label": "Default Zoom",
              "type": "number",
              "minimum": 0.25,
              "maximum": 8.0,
              "step": 0.25,
              "default": 1.0,
              "description": "Default pixels-per-sample zoom for newly opened raw browser views."
            },
            {
              "id": "show_status_messages",
              "label": "Show Browser Status Messages",
              "type": "boolean",
              "default": true,
              "description": "Controls whether browser state updates are echoed into the studio output panels."
            }
          ],
          "actions": [
            {
              "id": "save",
              "label": "Save Settings"
            },
            {
              "id": "restore_defaults",
              "label": "Restore Defaults"
            }
          ]
        }
      ]
    }
  }
}
