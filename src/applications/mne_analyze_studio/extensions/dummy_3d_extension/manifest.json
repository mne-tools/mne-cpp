{
  "id": "dummy-3d-extension",
  "display_name": "Inspect 3D Extension",
  "version": "0.2.0",
  "entry_point": "inspect_3d_surface_view",
  "contributes": {
    "view_providers": [
      {
        "id": "inspect3d.surface_view",
        "display_name": "Inspect Surface View",
        "widget_type": "inspect_3d_surface",
        "slot": "center",
        "file_extensions": [
          ".surf",
          ".pial",
          ".white",
          ".inflated",
          ".orig",
          ".bem"
        ],
        "supports_scene_merging": true
      }
    ],
    "ui": {
      "sidebar_items": [
        "Inspect 3D"
      ],
      "menu_items": [
        "View/Inspect 3D"
      ]
    }
  }
}
