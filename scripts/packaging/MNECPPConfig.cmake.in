@PACKAGE_INIT@

#
#  MNECPPConfig.cmake — generated by CMake for MNE-CPP @MNE_CPP_VERSION@
#
#  After a successful find_package(MNE-CPP) the following imported targets
#  are available:
#
#    MNE-CPP::mne_utils       MNE-CPP::mne_math       MNE-CPP::mne_fiff
#    MNE-CPP::mne_fs          MNE-CPP::mne_mne        MNE-CPP::mne_fwd
#    MNE-CPP::mne_inv         MNE-CPP::mne_com        MNE-CPP::mne_conn
#    MNE-CPP::mne_dsp         MNE-CPP::mne_lsl        MNE-CPP::mne_mri
#    MNE-CPP::mne_disp        MNE-CPP::mne_disp3D
#
#  Usage:
#    find_package(MNE-CPP 2.0.0 REQUIRED)
#    target_link_libraries(my_app PRIVATE MNE-CPP::mne_fiff MNE-CPP::mne_mne)
#
#  Legacy variables (for compatibility with non-target-based projects):
#    MNE_CPP_FOUND          - TRUE
#    MNE_CPP_INCLUDE_DIRS   - Include directories
#    MNE_CPP_LIBRARY_DIRS   - Library directories
#    MNE_CPP_LIBRARIES      - List of library names
#    MNE_CPP_VERSION        - Version string
#

include(CMakeFindDependencyMacro)

# MNE-CPP requires Qt (Core at minimum; GUI libs need more components)
find_dependency(Qt6 COMPONENTS Core Concurrent Gui Network Widgets Svg Xml OpenGL OpenGLWidgets)

# Eigen is a header-only dependency used in MNE-CPP public headers.
# It is bundled with MNE-CPP and installed alongside it.
if(NOT TARGET Eigen3::Eigen)
    find_dependency(Eigen3 HINTS "${PACKAGE_PREFIX_DIR}/share/eigen3/cmake"
                                 "${PACKAGE_PREFIX_DIR}/lib/cmake/eigen3")
endif()

# Import the MNE-CPP library targets
include("${CMAKE_CURRENT_LIST_DIR}/MNECPPTargets.cmake")

# MNE-CPP public headers include <QtCore/qglobal.h> and <Eigen/Core>,
# so ensure Qt::Core and Eigen3::Eigen propagate to consuming targets.
set(_mnecpp_all_targets
    mne_utils mne_math mne_fiff mne_fs mne_mne mne_fwd mne_inv
    mne_com mne_conn mne_dsp mne_lsl mne_mri mne_disp mne_disp3D
)
foreach(_t IN LISTS _mnecpp_all_targets)
    if(TARGET MNE-CPP::${_t})
        set_property(TARGET MNE-CPP::${_t} APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES Qt6::Core Eigen3::Eigen)
    endif()
endforeach()
unset(_mnecpp_all_targets)
unset(_t)

# Legacy variables for downstream projects that don't use targets
set(MNE_CPP_FOUND TRUE)
set(MNE_CPP_VERSION "@MNE_CPP_VERSION@")
set(MNE_CPP_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/include")
set(MNE_CPP_LIBRARY_DIRS "${PACKAGE_PREFIX_DIR}/lib")

set(MNE_CPP_LIBRARIES
    mne_utils
    mne_math
    mne_fiff
    mne_fs
    mne_mne
    mne_fwd
    mne_inv
    mne_com
    mne_conn
    mne_dsp
    mne_lsl
    mne_mri
    mne_disp
    mne_disp3D
)

check_required_components(MNE-CPP)
